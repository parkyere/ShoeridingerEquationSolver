{
    "version": 5,
    "configurePresets": [
        {
            "name": "msvc-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "SES_ENABLE_AVX2": "ON",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "VCPKG_HOST_TRIPLET": "x64-windows-static",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
        },
        {
            "name": "msvc-release",
            "displayName": "Windows MSVC Release (static)",
            "description": "Windows Release build. All deps static via vcpkg x64-windows-static (static libraries + static CRT). FIRST configure builds Qt from source (slow once, then binary-cached). Bootstrap external/vcpkg/bootstrap-vcpkg.bat and configure from an MSVC vcvarsall x64 environment.",
            "inherits": "msvc-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "msvc-debug",
            "displayName": "Windows MSVC Debug (static)",
            "description": "Windows Debug build (static via vcpkg x64-windows-static). WARNING: unoptimized -- the 3D physics/FFT tests take minutes; use for stepping through code.",
            "inherits": "msvc-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "SES_ENABLE_AVX2": "ON",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET": "x64-linux"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release (static)",
            "description": "Linux Release build. Deps static via vcpkg x64-linux (static libraries; glibc stays dynamic, as is standard on Linux). Portable AVX2 (bitwise-reproducible oracles). First configure builds Qt from source (slow once, then cached). Bootstrap external/vcpkg/bootstrap-vcpkg.sh first.",
            "inherits": "linux-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug (static)",
            "description": "Linux Debug build (static via vcpkg x64-linux). WARNING: unoptimized -- the 3D physics/FFT tests take minutes.",
            "inherits": "linux-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        }
    ],
    "buildPresets": [
        { "name": "msvc-release", "configurePreset": "msvc-release" },
        { "name": "msvc-debug", "configurePreset": "msvc-debug" },
        { "name": "linux-release", "configurePreset": "linux-release" },
        { "name": "linux-debug", "configurePreset": "linux-debug" }
    ],
    "testPresets": [
        { "name": "msvc-release", "configurePreset": "msvc-release", "output": { "outputOnFailure": true } },
        { "name": "msvc-debug", "configurePreset": "msvc-debug", "output": { "outputOnFailure": true } },
        { "name": "linux-release", "configurePreset": "linux-release", "output": { "outputOnFailure": true } },
        { "name": "linux-debug", "configurePreset": "linux-debug", "output": { "outputOnFailure": true } }
    ]
}
