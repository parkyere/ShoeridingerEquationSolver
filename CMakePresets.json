{
    "version": 5,
    "configurePresets": [
        {
            "name": "msvc-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "SES_ENABLE_AVX2": "ON",
                "CMAKE_PREFIX_PATH": "C:/Qt/6.8.1/msvc2022_64"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
        },
        {
            "name": "mingw-base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "SES_ENABLE_AVX2": "ON",
                "CMAKE_C_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/g++.exe",
                "CMAKE_MAKE_PROGRAM": "C:/Qt/Tools/Ninja/ninja.exe",
                "CMAKE_PREFIX_PATH": "C:/Qt/6.8.1/mingw_64"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
        },
        {
            "name": "msvc",
            "displayName": "MSVC RelWithDebInfo (AVX2, Qt msvc2022_64)",
            "description": "Default for development: optimized enough for the 3D physics, still debuggable.",
            "inherits": "msvc-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "msvc-release",
            "displayName": "MSVC Release (AVX2, Qt msvc2022_64)",
            "description": "Full optimization, no debug info.",
            "inherits": "msvc-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "msvc-debug",
            "displayName": "MSVC Debug (AVX2, Qt msvc2022_64)",
            "description": "WARNING: unoptimized -- the 3D physics tests take minutes. Use for stepping through code only.",
            "inherits": "msvc-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "mingw",
            "displayName": "MinGW RelWithDebInfo (AVX2, Qt mingw_64)",
            "description": "Qt-bundled GCC 13.1 (the scripted build tree).",
            "inherits": "mingw-base",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "mingw-release",
            "displayName": "MinGW Release (AVX2, Qt mingw_64)",
            "inherits": "mingw-base",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "mingw-debug",
            "displayName": "MinGW Debug (AVX2, Qt mingw_64)",
            "description": "WARNING: unoptimized -- the 3D physics tests take minutes.",
            "inherits": "mingw-base",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "SES_ENABLE_AVX2": "ON"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
        },
        {
            "name": "linux",
            "displayName": "Linux RelWithDebInfo (AVX2, system Qt6)",
            "description": "Safe default: portable AVX2 (bitwise-reproducible tests); compiler = system default.",
            "inherits": "linux-base"
        },
        {
            "name": "linux-native",
            "displayName": "Linux RelWithDebInfo (-march=native, newest clang/gcc)",
            "description": "Host-tuned (-march=native, pinned to 256-bit vectors) + newest clang++/g++. Stays bitwise-reproducible with the AVX2 oracles even on AVX-512, so it works for the app AND the test suite.",
            "inherits": "linux-base",
            "cacheVariables": {
                "SES_NATIVE": "ON",
                "SES_AUTODETECT_COMPILER": "ON"
            }
        },
        {
            "name": "linux-clang",
            "displayName": "Linux Clang (AVX2)",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "linux-gcc",
            "displayName": "Linux GCC (AVX2)",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        }
    ],
    "buildPresets": [
        { "name": "msvc", "configurePreset": "msvc" },
        { "name": "msvc-release", "configurePreset": "msvc-release" },
        { "name": "msvc-debug", "configurePreset": "msvc-debug" },
        { "name": "mingw", "configurePreset": "mingw" },
        { "name": "mingw-release", "configurePreset": "mingw-release" },
        { "name": "mingw-debug", "configurePreset": "mingw-debug" },
        { "name": "linux", "configurePreset": "linux" },
        { "name": "linux-native", "configurePreset": "linux-native" },
        { "name": "linux-clang", "configurePreset": "linux-clang" },
        { "name": "linux-gcc", "configurePreset": "linux-gcc" }
    ],
    "testPresets": [
        { "name": "msvc", "configurePreset": "msvc", "output": { "outputOnFailure": true } },
        { "name": "msvc-release", "configurePreset": "msvc-release", "output": { "outputOnFailure": true } },
        { "name": "mingw", "configurePreset": "mingw", "output": { "outputOnFailure": true } },
        { "name": "mingw-release", "configurePreset": "mingw-release", "output": { "outputOnFailure": true } },
        { "name": "linux", "configurePreset": "linux", "output": { "outputOnFailure": true } },
        { "name": "linux-native", "configurePreset": "linux-native", "output": { "outputOnFailure": true } }
    ]
}
