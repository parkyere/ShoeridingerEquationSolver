#version 450

// psi <- scale * conj(psi). With a forward FFT this composes the inverse
// transform (conj -> FFT -> conj/N). std140 UBO n + scale (binding 1).
layout(local_size_x = 256) in;

layout(std430, binding = 0) buffer DataBuf { vec2 data[]; };

layout(std140, binding = 1) uniform Params {
    uint n;
    float scale;
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < n) {
        data[i] = scale * vec2(data[i].x, -data[i].y);
    }
}
