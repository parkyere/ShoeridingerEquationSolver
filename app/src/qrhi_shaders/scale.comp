#version 450

// data <- scale * data (the fp32 drift renormalization). One thread per
// element. Bindings: data(0) read-write, std140 UBO n + scale (1).
layout(local_size_x = 256) in;

layout(std430, binding = 0) buffer DataBuf { vec2 data[]; };

layout(std140, binding = 1) uniform Params {
    uint n;
    float scale;
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < n) {
        data[i] = scale * data[i];
    }
}
