{
    "version": "0.2.0",
    "configurations": [
        {
            // F5: build the active preset, then launch/debug the CMake launch
            // target. Select `sesolver_app` as the launch target once in the
            // CMake Tools status bar; thereafter F5 just works.
            "name": "sesolver_app (build + run)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${command:cmake.launchTargetDirectory}",
            "environment": [],
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "preLaunchTask": "cmake-build",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
