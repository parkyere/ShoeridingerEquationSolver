{
    "version": "2.0.0",
    "tasks": [
        {
            // Build ALL targets of the active preset via the CMake Tools
            // extension -- it supplies the kit environment itself (on Windows
            // a plain shell `cmake --build` fails without vcvars; the
            // extension task does not). Ctrl+Shift+B.
            "label": "cmake-build",
            "type": "cmake",
            "command": "build",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": [],
            "detail": "CMake Tools: build the active preset (all targets)"
        },
        {
            // The F5 preLaunchTask: just the app target, for a fast edit ->
            // F5 loop (vkcheck/tests build via cmake-build or ctest).
            "label": "cmake-build-app",
            "type": "cmake",
            "command": "build",
            "targets": ["sesolver_app"],
            "problemMatcher": [],
            "detail": "CMake Tools: build sesolver_app for the active preset"
        }
    ]
}
