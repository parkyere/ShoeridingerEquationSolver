{
    "version": "2.0.0",
    "tasks": [
        {
            // Build the ACTIVE CMake preset's binary dir (all targets, incl.
            // sesolver_app). Used as the F5 preLaunchTask.
            "label": "cmake-build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "${command:cmake.buildDirectory}"],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "detail": "cmake --build <active preset build dir>"
        }
    ]
}
