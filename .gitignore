# Build trees
/build/
/build-*/
/out/
/cmake-build-*/
/vcpkg_installed/

# CMake artifacts
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
_deps/

# Compiled objects / binaries
*.o
*.obj
*.a
*.lib
*.dll
*.so
*.so.*
*.dylib
*.exe
*.pdb
*.ilk

# Qt / moc / uic / rcc generated
*.moc
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.qmlc
*.jsc

# IDE / editor
/.vs/
/.idea/
# Ignore per-user VSCode state, but SHARE the workspace config (F5 build/run,
# CMake Tools presets, recommended extensions) so it reaches other machines.
/.vscode/*
!/.vscode/settings.json
!/.vscode/launch.json
!/.vscode/tasks.json
!/.vscode/extensions.json
*.user
*.user.*

# OS cruft
Thumbs.db
.DS_Store
